{
  "name": "yt-notify-local-hub",
  "version": "1.0.0",
  "description": "YouTube Webhook Notification and Video Downloader",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "build:client": "cd client && npm run build",
    "dist:win": "npm run build:client && electron-builder --win --publish never",
    "pack": "electron-builder --dir --publish never"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "express": "^4.19.2",
    "fast-xml-parser": "^4.4.1",
    "ffmpeg-static": "^5.3.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.levanhien54.yt-notify-local-hub",
    "productName": "YT-Notify Local Hub",
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "server/src/**/*",
      "server/package.json",
      "server/node_modules/**/*",
      "!server/node_modules/better-sqlite3/**/*",
      "!server/node_modules/.cache/**/*",
      "!**/*.test.js",
      "!**/test/**/*",
      "client/dist/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
